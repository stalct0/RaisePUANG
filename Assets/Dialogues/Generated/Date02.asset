  m_Script: {fileID: 11500000, guid: a14ba248080591843a816c52cec034f3, type: 3}
  m_Name: Date02
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: Date02
  storyKind: 0
  datingCharacter: 0
  datingLocation: 0
  startSceneId: 0
  scenes:
  - sceneId: 0
    lines:
    - speaker: 
      text: "(\uB0A8\uD559\uC0DD \uB3D9\uCC3D\uC758 \uC8FC\uC120\uC73C\uB85C \uB9C8\uC8FC
        \uC549\uC740 \uC138 \uBA85\uC758 \uBBF8\uC18C\uB140\uB4E4. \uD478\uC559\uC774\uB294
        \uAE34\uC7A5\uACFC \uAE30\uB300\uB97C \uD488\uACE0 \uCE68\uC744 \uAFC0\uAEBD
        \uC0BC\uD0A8\uB2E4.)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB0A8\uD559\uC0DD"
      text: "\uC790\uC790~! \uB2E4\uB4E4 \uBAA8\uC600\uC73C\uB2C8\uAE4C \uC790\uAE30\uC18C\uAC1C\uBD80\uD130
        \uD558\uC790\uACE0. \uC5EC\uAE30 \uB0B4 \uC624\uB978\uCABD \uBD84\uBD80\uD130
        \uBA3C\uC800 \uD574\uC8FC\uC2E4\uB798\uC694?"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uCCAB \uBC88\uC9F8\uB85C \uB2E8\uC815\uD558\uACE0 \uCC28\uAC00\uC6B4
        \uC778\uC0C1\uC758 \uD751\uBC1C \uB0C9\uBBF8\uB140\uAC00 \uC220\uC794\uC744
        \uB0B4\uB824\uB193\uC73C\uBA70 \uC785\uC744 \uC5F0\uB2E4.)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uBBF8\uC694\uCF54"
      text: "\uC548\uB155\uD558\uC138\uC694. \uC774\uBC88\uC5D0 \uC218\uC11D\uC73C\uB85C
        \uC785\uD559\uD55C \uACFC\uB300, \uBBF8\uC694\uCF54\uB77C\uACE0 \uD569\uB2C8\uB2E4.
        \uC798 \uBD80\uD0C1\uB4DC\uB824\uC694."
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC5D0..\uC5D0\uB610.. \uC77C\uBCF8\uC778\uC778\uAC00\uC694?"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uBBF8\uC694\uCF54"
      text: "\uD558\uC544\u2026\u2026? \uCC98\uC74C \uBCF8 \uC0AC\uB78C \uC774\uB984
        \uAC00\uC9C0\uACE0 \uC2DC\uBE44 \uAC70\uB294 \uAC8C \uC774\uCABD \uCDE8\uBBF8\uC778\uAC00\uC694?
        \uAD49\uC7A5\uD788 \uBD88\uCF8C\uD558\uB124\uC694."
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uD788\uC775\u2026\u2026! (\uC9C0, \uC9C4\uC9DC \uBB34\uC12D\uB2E4!!
        \uB208\uBE5B\uC73C\uB85C \uC0AC\uB78C\uC744 \uC370\uC5B4\uBC84\uB9B4 \uAC83
        \uAC19\uC544!)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "\uC8C4, \uC8C4\uC1A1\uD569\uB2C8\uB2E4\uC544\uC544\u2026\u2026!"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB0A8\uD559\uC0DD"
      text: "\uC544\uD558\uD558\u2026\u2026! \uBBF8\uC694\uCF54 \uC528, \uD654\uB0B4\uC9C0
        \uB9C8\uC138\uC694! \uC774 \uC790\uC2DD\uC774 \uB300\uD559 \uC640\uC11C \uBBF8\uC18C\uB140\uB4E4\uC744
        \uCC98\uC74C \uBD10\uC11C \uB1CC \uACFC\uBD80\uD558\uAC00 \uC654\uB098 \uBD10\uC694!"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uCE59\uC1FC..! \uC9C4\uC9DC \uC5B5\uC6B8\uD558\uB2E4\uACE0!!! \uB0B4\uAC00
        \uBB58 \uADF8\uB807\uAC8C \uC798\uBABB\uD588\uB294\uB370?! \uB204\uAC00 \uBD10\uB3C4
        \uC77C\uBCF8 \uC774\uB984\uC774\uC796\uC544..? \uC5B4\uC774..!)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB0A8\uD559\uC0DD"
      text: "\uC790\uC790~! \uBBF8\uC694\uCF54 \uC528\uC758 \uC644\uBCBD\uD55C \uC790\uAE30\uC18C\uAC1C
        \uC798 \uB4E4\uC5C8\uACE0\uC694! \uBD84\uC704\uAE30 \uBC14\uAFD4\uC11C \uB2E4\uC74C
        \uBD84~! \uAC70\uAE30 \uAE08\uBC1C \uD2B8\uC708\uD14C\uC77C\uC774 \uC5C4\uCCAD
        \uC798 \uC5B4\uC6B8\uB9AC\uC2DC\uB294 \uCE20\uBB34\uAE30 \uC9F1\uB3C4 \uC790\uAE30\uC18C\uAC1C
        \uBD80\uD0C1\uD574\uC694!"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uB3D9\uCC3D\uC758 \uB9D0\uC774 \uB05D\uB098\uAE30 \uBB34\uC12D\uAC8C,
        \uD654\uB824\uD55C \uAE08\uBC1C \uD2B8\uC708\uD14C\uC77C\uC744 \uD719 \uCC30\uB791\uAC70\uB9AC\uBA70
        \uD314\uC9F1\uC744 \uB080 \uCC44 \uB098\uB97C \uB9E4\uC12D\uAC8C \uC9F8\uB824\uBCF4\uB294
        \uBBF8\uC18C\uB140.)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uD558\uC544? \uB204\uAC00 \uCE20\uBB34\uAE30 \uC9F1\uC774\uC57C? \uCE5C\uD55C
        \uC0AC\uC774\uB3C4 \uC544\uB2CC\uB370 \uBA4B\uB300\uB85C '\uC9F1' \uBD99\uC5EC\uC11C
        \uBD80\uB974\uC9C0 \uB9D0\uC544 \uC904\uB798?"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "\u2026\u2026\uBB50, \uBB3C\uC5B4\uBCF4\uB2C8\uAE4C \uB300\uB2F5\uC740
        \uD574 \uC8FC\uACA0\uB294\uB370. \uB0B4 \uC774\uB984\uC740 \uCE20\uBB34\uAE30\uC57C.
        \uB531\uD788 \uB108\uD76C\uAC00 \uC88B\uC544\uC11C \uB098\uC628 \uBBF8\uD305\uC740
        \uC544\uB2C8\uB2C8\uAE4C, \uAD1C\uD788 \uC624\uD574 \uAC19\uC740 \uAC70 \uD558\uC9C0
        \uB9C8!"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\u2026\u2026\uC800\uAE30, \uC8C4\uC1A1\uD55C\uB370 \uD55C \uAC00\uC9C0\uB9CC
        \uBB3C\uC5B4\uBD10\uB3C4 \uB420\uAE4C\uC694?"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uC559? \uBB54\uB370? \uD560 \uB9D0 \uC788\uC73C\uBA74 \uB611\uBC14\uB85C
        \uB9D0\uD574!"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC5D0\uB610... \uC77C\uBCF8\uC778\uC774\uC2E0\uAC00\uC694?"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uD558\uC544?! \uBC14\uCE74\uC7C8\uB098\uC774\uB178?! \uB0B4\uAC00 \uC65C
        \uC77C\uBCF8\uC778\uC778\uB370! \uB098 \uD0DC\uC5B4\uB098\uC11C \uC77C\uBCF8\uC740\uCEE4\uB155
        \uC81C\uC8FC\uB3C4\uBC16\uC5D0 \uC548 \uAC00\uBCF8 \uD1A0\uC885 \uD55C\uAD6D\uC778\uC774\uAC70\uB4E0?!"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC544\uB2C8 \u314B\u314B\u314B\u314B\u314B. \uC774\uB984\uC774 \uB300\uB193\uACE0
        '\uCE20\uBB34\uAE30'\uC5D0\uB2E4\uAC00 \uBC29\uAE08 \uB300\uC0AC\uB3C4 \uC644\uC804
        '\uB531\uD788 \uB108 \uC88B\uC544\uC11C \uADF8\uB7F0 \uAC70 \uC544\uB2C8\uB2C8\uAE4C
        \uC624\uD574\uD558\uC9C0 \uB9C8!'\uB77C\uB294 \uC815\uC11D \uCE24\uB370\uB808
        \uC2EC\uC9C0\uC5B4 \uAE08\uBC1C \uD2B8\uC708\uD14C\uC77C\uC774\uACE0! \uADF8\uB9AC\uACE0..
        \uBC29\uAE08 \uC77C\uBCF8\uC5B4\uD55C \uAC70 \uC544\uB0D0..??)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "\uC8C4, \uC8C4\uC1A1\uD569\uB2C8\uB2E4\uC544\uC544\u2026\u2026!"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uCE20\uBB34\uAE30\uB294 \uACE0\uAC1C\uB97C \uD671 \uB3CC\uB9AC\uBA70
        \uBEA8\uC744 \uBD80\uD480\uB9AC\uC9C0\uB9CC, \uADC0\uB05D\uC774 \uC0B4\uC9DD
        \uBD89\uC5B4\uC838 \uC788\uB2E4.)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uCE74.. \uCE74\uC640\uC774..!)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB0A8\uD559\uC0DD"
      text: "\uC790, \uC790! \uBD84\uC704\uAE30 \uAC00\uB77C\uC549\uD788\uC9C0 \uB9D0\uACE0~!
        \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uC6B0\uB9AC \uBBF8\uD305\uC758 \uAD6C\uC6D0\uD22C\uC218,
        \uAC08\uC0C9 \uBA38\uB9AC\uAC00 \uB108\uBB34 \uC798 \uC5B4\uC6B8\uB9AC\uB294
        \uC5EC\uC131\uBD84! \uC790\uAE30\uC18C\uAC1C \uBD80\uD0C1\uD574\uC694!"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uBBF8\uC694\uCF54\uC640 \uCE20\uBB34\uAE30\uC758 \uB0A0 \uC120 \uBC18\uC751
        \uB54C\uBB38\uC5D0 \uD478\uC559\uC774\uAC00 \uC794\uB729 \uCAC4\uC544\uC788\uB294
        \uC640\uC911, \uB9C8\uC8FC \uC549\uC740 \uAC08\uC0C9 \uBA38\uB9AC\uC758 \uBBF8\uC18C\uB140\uAC00
        \uC0DD\uAE0B \uC6C3\uC73C\uBA70 \uBD84\uC704\uAE30\uB97C \uBD80\uB4DC\uB7FD\uAC8C
        \uC804\uD658\uD55C\uB2E4.)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uC548\uB155\uD558\uC138\uC694. \uC774\uBC88\uC5D0 \uC2E0\uC785\uC0DD\uC73C\uB85C
        \uB4E4\uC5B4\uC628 \uC720\uC6B0\uCE74\uB77C\uACE0 \uD569\uB2C8\uB2E4. \uB9CC\uB098\uC11C
        \uBC18\uAC00\uC6CC\uC694."
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC73C\uC544\uC544\u2026\u2026 \uCC9C\uC0AC\uB2E4. \uC774 \uC0AD\uB9C9\uD55C
        \uBBF8\uD305 \uC790\uB9AC\uC5D0 \uB4DC\uB514\uC5B4 \uAD6C\uC6D0\uC790\uAC00
        \uB098\uD0C0\uB0AC\uC5B4\u2026\u2026! \uC778\uC0C1\uB3C4 \uD3EC\uADFC\uD55C
        \uAC8C \uC644\uC804 \uD790\uB9C1\uCE90\uC796\uC544.)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uC720\uC6B0\uCE74\uC758 \uB530\uB73B\uD55C \uBBF8\uC18C\uC5D0 \uC6A9\uAE30\uB97C
        \uC5BB\uC740 \uD478\uC559\uC774\uAC00 \uC870\uC2EC\uC2A4\uB7FD\uAC8C, \uD558\uC9C0\uB9CC
        \uBC84\uB9B4 \uC218 \uC5C6\uB294 \uC758\uBB38\uC744 \uB2F4\uC544 \uC2AC\uCA4D
        \uBB3C\uC5B4\uBCF8\uB2E4.)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC800, \uC800\uAE30\u2026\u2026 \uC720\uC6B0\uCE74 \uC528? \uD639\uC2DC
        \uC720\uC6B0\uCE74 \uC528\uB3C4\u2026\u2026 \uC77C\uBCF8\uC778\uC774\uC2E0\uAC00\uC694?"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uC544\uD558\uD558, \uC81C \uC774\uB984 \uB54C\uBB38\uC5D0 \uB2E4\uB4E4
        \uC790\uC8FC \uC624\uD574\uD558\uC2DC\uB354\uB77C\uACE0\uC694! \uC544\uB2C8\uC694,
        \uC800 \uC644\uC804 \uD1A0\uC885 \uD55C\uAD6D\uC778\uC774\uC5D0\uC694! \uBD80\uBAA8\uB2D8\uC774
        \uD55C\uC790 \uC774\uB984\uC744 \uC870\uAE08 \uD2B9\uC774\uD558\uAC8C \uC9C0\uC5B4\uC8FC\uC168\uC744
        \uBFD0\uC774\uB78D\uB2C8\uB2E4."
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uCF54\uC774\uCE20 wwwwwwww \uB2E4 \uC815\uC2E0 \uB098\uAC04\uAC70
        \uC544\uB2C8\uB0D0\uACE0 \uC5B4\uC774\u314B\u314B\u314B\u314B \uC5B4\uB5BB\uAC8C
        \uD55C\uAD6D \uC0AC\uB78C\uC774\uB984\uC774 \uC720\uC6B0\uCE74 \u314B\u314B\u314B\u314B\u314B\u314B\u314B\u314B\u314B)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uADF8\uB7EC\uB2C8\uAE4C \uB108\uBB34 \uBD80\uB2F4 \uAC16\uC9C0 \uB9C8\uC2DC\uACE0
        \uD3B8\uD558\uAC8C \uB9D0\uC500\uD558\uC154\uB3C4 \uB3FC\uC694, \uD478\uC559
        \uC528. \uC544\uAE4C\uBD80\uD130 \uAE34\uC7A5\uD558\uC2E0 \uAC83 \uAC19\uC544\uC11C
        \uC74C\uB8CC\uC218\uB77C\uB3C4 \uC880 \uB530\uB77C\uB4DC\uB9B4\uAE4C\uC694?"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC6B0\uC640\uC544\u2026\u2026 \uAC10\uACA9\uC774\uC57C. \uC55E\uC758
        \uB450 \uACE0\uC2B4\uB3C4\uCE58\uB4E4\uC774\uB791 \uB2E4\uB974\uAC8C \uB9D0\uB3C4
        \uB108\uBB34 \uC608\uC058\uAC8C \uC798 \uD558\uC796\uC544! \uC774\uB984\uC774
        100% \uBBF8\uC5F0\uC2DC \uC18C\uAFC9\uCE5C\uAD6C \uC77C\uBCF8 \uC774\uB984\uC774\uB4E0
        \uB9D0\uB4E0 \uC774\uC81C \uC0C1\uAD00\uC5C6\uC5B4. \uC774 \uD3EC\uADFC\uD568,
        \uC774 \uBC30\uB824\uC2EC\u2026\u2026 \uB0B4 \uB9C8\uC74C\uC18D \uBA54\uC778
        \uD788\uB85C\uC778\uC740 \uC624\uB298\uBD80\uD130 \uBB34\uC870\uAC74 \uC720\uC6B0\uCE74
        \uC528\uB2E4!!)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uB098\uB294 \uB204\uAD6C\uB97C \uC120\uD0DD\uD560\uAE4C?)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
