  m_Script: {fileID: 11500000, guid: a14ba248080591843a816c52cec034f3, type: 3}
  m_Name: Date31
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: Date31
  storyKind: 0
  datingCharacter: 0
  datingLocation: 0
  startSceneId: 0
  scenes:
  - sceneId: 1
    lines:
    - speaker: 
      text: "(\uC2A4\uC73D, \uBB38\uC774 \uC5F4\uB9AC\uBA70 \uB538\uB791\uC774\uB294
        \uC885\uC18C\uB9AC. \uBC29 \uC548 \uAC00\uB4DD \uADC0\uC5EC\uC6B4 \uACE0\uC591\uC774\uB4E4\uC774
        \uAC00\uB4DD\uD558\uB2E4.)"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uCE20\uBB34\uAE30\uC640 \uB4DC\uB514\uC5B4 \uB3C4\uCC29\uD55C \uACE0\uC591\uC774
        \uCE74\uD398. \uD3C9\uC18C\uC5D4 \uAE4C\uCE60\uD558\uAE30 \uC9DD\uC774 \uC5C6\uB358
        \uCE20\uBB34\uAE30\uC600\uC9C0\uB9CC, \uBB38\uC744 \uC5F4\uC790\uB9C8\uC790
        \uB208\uBE5B\uC774 \uBC18\uC9DD\uC774\uAE30 \uC2DC\uC791\uD588\uB2E4.)"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\u2026\u2026\uC557."
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_surprised
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uB208\uC744 \uBE5B\uB0B4\uBA70 \uBA3C\uC9C0 \uAC19\uC740 \uC544\uAE30
        \uACE0\uC591\uC774\uC5D0\uAC8C \uB2E4\uAC00\uAC04\uB2E4)"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_surprised
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uCE20\uBB34\uAE30\uB294 \uC8FC\uBCC0\uC5D0 \uB0B4\uAC00 \uC788\uB2E4\uB294
        \uAC83\uB3C4 \uC78A\uC740 \uCC44, \uACE0\uC591\uC774 \uC55E\uC5D0 \uD138\uC369
        \uC8FC\uC800\uC549\uC558\uB2E4. \uADF8\uB7EC\uB354\uB2C8 \uB450 \uC190\uC744
        \uC591\uBCFC \uC606\uC73C\uB85C \uC62C\uB9AC\uACE0 \uC8FC\uBA39\uC744 \uC950\uB354\uB2C8\u2026\u2026
        \uB0E5\uB0E5, \uD558\uACE0 \uC190\uB3D9\uC791\uC744 \uB530\uB77C \uD558\uAE30
        \uC2DC\uC791\uD558\uB294 \uAC8C \uC544\uB2CC\uAC00!)"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uB0E5.. \uB0E5! \uB0D0\uC639!"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uC2EC\uC7A5\uC744 \uBD80\uC5EC\uC7A1\uC73C\uBA70 \uB098\uB3C4 \uBAA8\uB974\uAC8C)
        \u2026\u2026\uD06D, \uCE74\uC640\uC774.."
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uD760\uCE6B \uB180\uB77C\uBA70 \uB85C\uBD07\uCC98\uB7FC \uC090\uAC71\uAC70\uB9AC\uBA70
        \uB4A4\uB97C \uB3CC\uC544\uBCF8\uB2E4. \uC5BC\uAD74\uC774 \uD64D\uB2F9\uBB34\uCC98\uB7FC
        \uBE68\uAC1C\uC838 \uC788\uB2E4)"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uD478\uD478...\uD478..\uD478, \uD478\uC559 \uCFE4?! \uB2C8\uAC00 \uC65C
        \uAC70\uAE30\uC5D0 \uC788\uB294\uAC70\uC57C!! \uBC29\uAE08 \uBCF4\uACE0 \uC788\uC5C8\uB358\uAC70\uC9C0!!"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC544\uB2C8.. \uCE20\uBB34\uAE30\uCA29..? \uC6B0\uB9AC \uAC19\uC774
        \uB370\uC774\uD2B8\uD558\uB7EC \uC654\uC796\uC544..?!"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uD558\uC544?! \uBC29\uAE08 \uBB50,,? \uADC0, \uADC0\uC5FD\uB2E4\uB2C8
        \uB204\uAC00?! \uB0B4\uAC00?! \uCC38\uB098, \uAE30\uAC00 \uB9C9\uD600\uC11C!"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uC6B0\uC73C.. \uB098\uB294 \uC544\uBB34 \uB9D0\uB3C4 \uC548\uD588\uAC70\uB4E0..?"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uCE20\uBB34\uAE30\uB294 \uADC0 \uB05D\uAE4C\uC9C0 \uC0C8\uBE68\uAC1C\uC9C4
        \uCC44\uB85C, \uB098\uB97C \uB9E4\uC12D\uAC8C \uB178\uB824\uBCF4\uBA70 \uB2E4\uAC00\uC654\uB2E4.
        \uD558\uC9C0\uB9CC \uB5A8\uB9AC\uB294 \uB208\uB3D9\uC790\uB294 \uC804\uD600
        \uC704\uD611\uC801\uC774\uC9C0 \uC54A\uC558\uB2E4.)"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_default
      leftAppearanceId: 
      rightAppearanceId: 
    hasChoice: 1
    choiceTextA: "\uBC29\uAE08 \uACE0\uC591\uC774 \uD749\uB0B4 \uB0B8\uAC70 \uBA54\uCC60
      \uCE74\uC640\uC774\uD588\uACE0..! \uC9C0\uAE08 \uC5BC\uAD74 \uBE68\uAC1C\uC9C0\uB2C8\uAE4C
      \uB354 \uADC0\uC5EC\uC6CC..!"
    nextSceneA: 10
    affectionA: 0
    girlfriendA: 0
    choiceTextB: "\uCE20\uBB34\uAE30\uCA29 \uD3C9\uC18C\uC5D0\uB294 \uAE4C\uCE60\uD558\uAC8C
      \uD2F1\uD2F1\uAC70\uB9AC\uC9C0\uB9CC... \uBC29\uAE08 \uBAA9\uC18C\uB9AC\uD1A4
      \uC5C4\uCCAD \uADC0\uC5EC\uC6E0\uC5B4..!"
    nextSceneB: 11
    affectionB: 0
    girlfriendB: 0
    choiceTextC: 
    nextSceneC: -1
    affectionC: 0
    girlfriendC: 0
    moneyChange: 0
    conditionChange: 0
    gradeChange: 0
    friendshipChange: 0
    completesDate: 0
  - sceneId: 10
    lines:
    - speaker: "\uB098"
      text: "\uBC29\uAE08 \uACE0\uC591\uC774 \uD749\uB0B4 \uB0B8\uAC70 \uBA54\uCC60
        \uCE74\uC640\uC774\uD588\uACE0..! \uC9C0\uAE08 \uC5BC\uAD74 \uBE68\uAC1C\uC9C0\uB2C8\uAE4C
        \uB354 \uADC0\uC5EC\uC6CC..!"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uB0D0, \uB0E5\uB0E5\uC774\uB77C\uB2C8 \uB0B4\uAC00 \uC5B8\uC81C \uADF8\uB7F0
        \uC720\uCE58\uD55C \uC9D3\uC744\u2026\u2026! \uADF8\uB9AC\uACE0 \uB0B4 \uC5BC\uAD74\uC774
        \uC5B4\uB514\uAC00 \uBE68\uAC1B\uB2E4\uB294 \uAC70\uC57C!!"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_angry
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uBD10\uBD10, \uC9C0\uAE08\uB3C4 \uADC0\uAE4C\uC9C0 \uB2E4 \uBE68\uAC1C\uC84C\uC796\uC544
        \u314B\u314B \uAC70\uC9D3\uB9D0 \uBABB \uD558\uB124, \uC57C\uB808\uC57C\uB808
        \uCE20\uBB34\uAE30 \uCA29~"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uBD80\uB044\uB7EC\uC6C0\uC774 \uADF9\uC5D0 \uB2EC\uD574 \uACE0\uAC1C\uB97C
        \uD479 \uC219\uC600\uB2E4\uAC00, \uC774\uB0B4 \uD5DB\uAE30\uCE68\uC744 \uD558\uBA70
        \uACF5\uC8FC\uB2D8\uCC98\uB7FC \uD131\uC744 \uCE58\uCF1C\uB4E0\uB2E4)"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uD765! \uD558\uAE34, \uBB50\u2026\u2026. \uC774\uC81C\uC57C \uB0B4
        \uC9C4\uAC00\uB97C \uC54C\uC544\uBCF8 \uBAA8\uC591\uC774\uB124?"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uADF8\uB798, \uB0B4\uAC00 \uC880 \uADC0\uC5FD\uAE34 \uD558\uC9C0! \uD750,
        \uD765! \uADF8\uB7EC\uB2C8\uAE4C \uC601\uAD11\uC73C\uB85C \uC54C\uB77C\uACE0?
        \uB0B4, \uB0B4\uAC00 \uD2B9\uBCC4\uD788\u2026\u2026 \uC624\uB298 \uB370\uC774\uD2B8\uAC00
        \uB05D\uB0A0 \uB54C\uAE4C\uC9C0\uB294 \uB124 \uC606\uC5D0 \uAC19\uC774 \uC788\uC5B4
        \uC904 \uD14C\uB2C8\uAE4C\u2026\u2026!"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uADF8\uB807\uAC8C \uCE20\uBB34\uAE30\uB294 \uB370\uC774\uD2B8\uAC00
        \uB05D\uB0A0 \uB54C\uAE4C\uC9C0 \uB0B4 \uC18C\uB9E4\uB97C \uAF2D \uC954 \uCC44,
        \uD3C9\uC18C\uC640 \uB2EC\uB9AC \uC21C\uC21C\uD788 \uB0B4 \uAC78\uC74C\uC5D0
        \uB9DE\uCDB0 \uAC78\uC5B4\uC8FC\uC5C8\uB2E4. \uC5BC\uAD74\uC758 \uBD89\uC740
        \uAE30\uB294 \uC27D\uAC8C \uAC00\uB77C\uC549\uC9C0 \uC54A\uC558\uC9C0\uB9CC,
        \uADF8\uB140\uC758 \uC785\uAC00\uC5D4 \uC791\uC740 \uBBF8\uC18C\uAC00 \uAC78\uB824
        \uC788\uC5C8\uB2E4.)"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    hasChoice: 0
    choiceTextA: 
    nextSceneA: -1
    affectionA: 0
    girlfriendA: 0
    choiceTextB: 
    nextSceneB: -1
