    completesDate: 0
  - sceneId: 11
    lines:
    - speaker: "\uB098"
      text: "\uCE20\uBB34\uAE30\uCA29 \uD3C9\uC18C\uC5D0\uB294 \uAE4C\uCE60\uD558\uAC8C
        \uD2F1\uD2F1\uAC70\uB9AC\uC9C0\uB9CC... \uBC29\uAE08 \uBAA9\uC18C\uB9AC\uD1A4
        \uC5C4\uCCAD \uADC0\uC5EC\uC6E0\uC5B4..!"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uC21C\uAC04 \uD45C\uC815\uC774 \uB531\uB531\uD558\uAC8C \uAD73\uB294\uB2E4)
        \u2026\u2026\uBB50? \uD3C9\uC18C\uC5D4 \uD2F1\uD2F1\uAC70\uB9B0\uB2E4\uACE0\u2026\u2026?"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_angry
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC544, \uC544\uB2C8, \uB0B4 \uB9D0\uC740 \uAC89\uC73C\uB85C\uB294 \uAE4C\uCE60\uD574
        \uBCF4\uC5EC\uB3C4 \uC18D\uC740 \uADC0\uC5FD\uB2E4\uB294 \uB73B\uC774\uC5C8\uB294\uB370\u2026\u2026!"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uB208\uB3D9\uC790\uAC00 \uAC00\uB298\uAC8C \uB5A8\uB9AC\uBA70, \uB0B4
        \uC2DC\uC120\uC744 \uD53C\uD55C\uB2E4) \u2026\u2026\uACB0\uAD6D \uD478\uC559
        \uCFE4 \uB208\uC5D0\uB294 \uB0B4\uAC00 \uB9E8\uB0A0 \uD654\uB9CC \uB0B4\uB294
        \uC774\uC0C1\uD55C \uC560\uB85C \uBCF4\uC600\uB2E4\uB294 \uAC70\uB124."
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_angry
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uCE20\uBB34\uAE30\uB294 \uB0B4 \uBB34\uC2EC\uD55C \uB9D0\uC5D0 \uB0B4\uC2EC
        \uD070 \uC0C1\uCC98\uB97C \uC785\uC740 \uB4EF\uD588\uB2E4. \uAC89\uC73C\uB85C\uB294
        \uD654\uB97C \uB0B4\uC9C0 \uC54A\uC558\uC9C0\uB9CC, \uCE20\uBB34\uAE30\uC758
        \uC785\uC220\uC774 \uBBF8\uC138\uD558\uAC8C \uD30C\uB974\uB974 \uB5A8\uB9AC\uACE0
        \uC788\uC5C8\uB2E4. )"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_default
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uACE0\uC591\uC774\uB97C \uBCF4\uB358 \uB530\uB73B\uD55C \uB208\uBE5B\uC740
        \uC628\uB370\uAC04\uB370\uC5C6\uC774 \uC0AC\uB77C\uC9C0\uACE0, \uC2AC\uD508
        \uAE30\uC0C9\uC774 \uC5ED\uB825\uD588\uB2E4.)"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_default
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uCE20, \uCE20\uBB34\uAE30 \uCA29?! \uADF8\uB7F0 \uB73B\uC774 \uC544\uB2C8\uB77C!"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uB410\uC5B4. \uB098 \uBA3C\uC800 \uAC08\uB798. \uD63C\uC790\uC11C \uACE0\uC591\uC774\uB791
        \uC798 \uB180\uB2E4 \uC640.."
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_default
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uC544\uCC28 \uC2F6\uC5C8\uC9C0\uB9CC \uC774\uBBF8 \uB2A6\uC5C8\uB2E4.
        \uC5B4\uCA54 \uC904 \uBAB0\uB77C \uD5C8\uB465\uB300\uB294 \uB098\uB97C \uB4A4\uB85C\uD55C
        \uCC44, \uCE20\uBB34\uAE30\uB294 \uCC28\uAC00\uC6CC\uC9C4 \uACF5\uAE30\uB9CC\uC744
        \uB0A8\uAE30\uACE0 \uCE74\uD398\uB97C \uB098\uAC00\uBC84\uB838\uB2E4.)"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uB098\uC758 \uB9D0 \uD55C\uB9C8\uB514\uB85C \uC778\uD574 \uCCAB \uB370\uC774\uD2B8\uB294
        \uCD5C\uC545\uC758 \uACB0\uB9D0\uC744 \uB9DE\uC774\uD558\uACE0 \uB9D0\uC558\uB2E4.)"
      backgroundId: Dating_catcafe
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
