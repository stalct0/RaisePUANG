--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a14ba248080591843a816c52cec034f3, type: 3}
  m_Name: Date12
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: Date12
  storyKind: 0
  datingCharacter: 0
  datingLocation: 0
  startSceneId: 0
  scenes:
  - sceneId: 0
    lines:
    - speaker: "\uB098"
      text: "(\uB180\uC774\uACF5\uC6D0\uC758 \uAF43, \uC2DC\uC18D 100km\uB85C \uC9C8\uC8FC\uD558\uB294
        \uC9C0\uC625\uC758 \uB864\uB7EC\uCF54\uC2A4\uD130 \uC55E. \uD478\uC559\uC774\uB294
        \uD0D1\uC2B9\uD558\uAE30\uB3C4 \uC804\uC5D0 \uC0AC\uC815\uC5C6\uC774 \uD754\uB4E4\uB9AC\uB294
        \uD2B8\uB799\uC744 \uBCF4\uBA70 \uC774\uBBF8 \uC548\uC0C9\uC774 \uD30C\uB797\uAC8C
        \uC9C8\uB824 \uC788\uB2E4.)"
      backgroundId: Dating_amuse_day
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC6B0\uC6B1.... \uBBF8\uCCE4\uB2E4. \uC800\uAC74 \uC18D\uB3C4\uAC10\uC774
        \uC2DC\uC18D 100km\uAC00 \uC544\uB2C8\uB77C \uBAA8\uB2C8\uD130 \uD504\uB808\uC784
        \uB808\uC774\uD2B8 \uC81C\uD55C\uC774 \uD480\uB9B0 \uAC83\uCC98\uB7FC \uBBF8\uCCD0
        \uB0A0\uB6F0\uACE0 \uC788\uC796\uC544! \uBCF4\uAE30\uB9CC \uD574\uB3C4 \uBA40\uBBF8\uAC00
        \uB098\uC11C \uC18D\uC774 \uB4A4\uC9D1\uD790 \uAC83 \uAC19\uC544\u2026\u2026!)"
      backgroundId: Dating_amuse_day
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uD478\uC559 \uCFE4, \uAD1C\uCC2E\uC544? \uC5BC\uAD74\uC774 \uC9C4\uC9DC
        \uD30C\uB797\uAC8C \uC9C8\uB838\uB294\uB370\u2026\u2026?"
      backgroundId: Dating_amuse_day
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_emabarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC73C, \uC751... \uC7A0\uAE50 \uC18D\uC774 \uC6B8\uB801\uAC70\uB9AC\uB294\uB370
        \uB098\uB294 \uBABB \uD0C8 \uAC83 \uAC19\uC544... \uB124 \uAC00\uBC29\uC774\uB791
        \uBB3C\uAC74 \uC880 \uB9E1\uC544\uB458\uAC8C.."
      backgroundId: Dating_amuse_day
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uC557, \uADF8\uB798? \uADF8\uB7FC \uB0B4 \uAC00\uBC29\uC774\uB791...
        \uD578\uB4DC\uD3F0\uB3C4 \uAC00\uC9C0\uACE0 \uC788\uC5B4 \uC904\uB798? \uB864\uB7EC\uCF54\uC2A4\uD130
        \uD0C8 \uB54C \uB5A8\uC5B4\uB728\uB9AC\uBA74 \uC548 \uB418\uB2C8\uAE4C!"
      backgroundId: Dating_amuse_day
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_default
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC815\uC2E0\uC774 \uC5C6\uB358 \uD478\uC559\uC774\uB294 \uC720\uC6B0\uCE74\uAC00
        \uAC74\uB128 \uD734\uB300\uD3F0\uC744 \uB300\uC218\uB86D\uC9C0 \uC54A\uAC8C
        \uC8FC\uBA38\uB2C8\uC5D0 \uC464\uC154 \uB123\uACE0 \uD654\uC7A5\uC2E4\uB85C
        \uC9C1\uD589\uD55C\uB2E4.)"
      backgroundId: Dating_amuse_day
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uB2A6\uC740 \uC800\uB141, \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uB098\uC640
        \uC720\uC6B0\uCE74\uB294 \uB300\uAD00\uB78C\uCC28\uC5D0 \uD0D1\uC2B9\uD558\uAE30\uB85C
        \uD588\uB2E4.)"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uAD00\uB78C\uCC28\uAC00 \uB290\uB9BF\uB290\uB9BF \uC815\uC0C1\uC5D0
        \uAC00\uAE4C\uC6CC\uC9C8\uC218\uB85D, \uC2DC\uB04C\uBC85\uC801\uD558\uB358
        \uB180\uC774\uACF5\uC6D0\uC758 \uC18C\uC74C\uC774 \uAC70\uC9D3\uB9D0\uCC98\uB7FC
        \uBA40\uC5B4\uC9C4\uB2E4. \uC881\uC740 \uACF5\uAC04\uC744 \uCC44\uC6B0\uB294
        \uAC74 \uC624\uC9C1 \uB450 \uC0AC\uB78C\uC758 \uC228\uC18C\uB9AC\uC640 \uD1B1\uB2C8\uBC14\uD034\uAC00
        \uB9DE\uBB3C\uB9AC\uB294 \uBBF8\uC138\uD55C \uC9C4\uB3D9\uBFD0\uC774\uB2E4.)"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(...\uC870\uC6A9\uD558\uB2E4.)"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uCC3D\uBC16 \uC800 \uBA40\uB9AC\uC120 \uC57C\uAC04 \uD37C\uB808\uC774\uB4DC\uC758
        \uD558\uC774\uB77C\uC774\uD2B8\uC778 \uD3ED\uC8FD\uC774 \uD558\uB298\uC744
        \uD654\uB824\uD558\uAC8C \uC218\uB193\uACE0 \uC788\uC9C0\uB9CC\u2026\u2026
        \uC774 \uC720\uB9AC\uCC3D \uB108\uBA38\uC758 \uC138\uACC4\uB294 \uB9C8\uCE58
        \uC2DC\uAC04\uC774 \uBA48\uCD98 \uAC83\uCC98\uB7FC \uACE0\uC694\uD558\uAE30\uB9CC
        \uD558\uB2E4.)"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC720\uC6B0\uCE74\uB294 \uAC00\uB9CC\uD788 \uCC3D\uBC16\uC744 \uBC14\uB77C\uBCF4\uBA70,
        \uD391, \uD391, \uC18C\uB9AC \uC5C6\uC774 \uD130\uC84C\uB2E4\uAC00 \uC774\uB0B4
        \uC2A4\uB7EC\uC9C0\uB294 \uC624\uC0C9\uBE5B\uAE54\uC758 \uD3ED\uC8FD \uC794\uC0C1\uC744
        \uB208\uC5D0 \uB2F4\uACE0 \uC788\uB2E4. \uB178\uC744\uC774 \uC9C0\uACE0 \uCC3E\uC544\uC628
        \uC5B4\uB460 \uC18D\uC5D0\uC11C, \uD3ED\uC8FD\uBE5B\uC774 \uC720\uC6B0\uCE74\uC758
        \uC606\uC5BC\uAD74\uC744 \uC544\uB828\uD558\uAC8C \uBE44\uCD98\uB2E4.)"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: ".....\uCC38 \uC608\uC058\uB2E4, \uADF8\uCE58? \uD478\uC559\uCFE4."
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC5B4? \uC73C\uC751, \uADF8\uB807\uB124.. \uC9C4\uC9DC \uD654\uB824\uD558\uB2E4."
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uC800\uAE30 \uD478\uB978 \uBC14\uB2E4 \uC18D\uC73C\uB85C\u266B"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uB0B4\uAC00 \uAC08 \uC218 \uC5C6\uC5B4\uB3C4\u266B.."
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC720\uC6B0\uCE74\uC9F1\uC774 \uCC3D\uBC16\uC744 \uBC14\uB77C\uBCF4\uBA70
        \uC544\uB828\uD558\uAC8C \uB178\uB798\uB97C \uBD80\uB978\uB2E4.)"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC5B4\uB514\uC120\uAC00 \uB4E4\uC5B4\uBCF8 \uB178\uB798\uAC19\uC740\uB370..
        \uBB50\uC9C0..?)"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC720\uC6B0\uCE74\uCA29, \uC800\uB141 \uBB50 \uBA39\uACE0\uC2F6\uC5B4?"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC21C\uAC04, \uC720\uC6B0\uCE74\uAC00 \uB178\uB798\uB97C \uB69D \uBA48\uCD94\uB354\uB2C8
        \uCC9C\uCC9C\uD788 \uACE0\uAC1C\uB97C \uB3CC\uB824 \uB098\uB97C \uBC14\uB77C\uBCF8\uB2E4.)"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uD750\uC74C... \uAE00\uC384..? \uC798 \uBAA8\uB974\uACA0\uB124..."
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_default
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC5B4, \uADF8\uB798? \uADF8\uB7FC \uB0B4\uB824\uAC00\uC11C \uCC9C\uCC9C\uD788
        \uACE8\uB77C\uBCFC\uAE4C?"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\u2026\u2026\uC751. \uD478\uC559 \uCFE4.."
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_default
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC720\uC6B0\uCE74 \uCA29\uC740 \uB2E4\uC2DC \uCC3D\uBC16\uC744 \uBC14\uB77C\uBCF4\uC558\uB2E4.)"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uB098 \uB610\uD55C \uB2E4\uC2DC \uD55C\uBC88 \uD3ED\uC8FD\uBE5B\uC774
        \uC544\uB828\uD558\uAC8C \uBC88\uC9C0\uB294 \uC720\uC6B0\uCE74\uC758 \uAC00\uB140\uB9B0
        \uC5B4\uAE68\uB97C \uBA4D\uD558\uB2C8 \uBC14\uB77C\uBCFC \uBFD0\uC774\uC5C8\uB2E4.
        \uB300\uAD00\uB78C\uCC28\uAC00 \uC644\uC804\uD788 \uBA48\uCDB0 \uC11C\uB294
        \uADF8 \uC21C\uAC04\uAE4C\uC9C0\uB3C4, \uC6B0\uB9AC\uB294 \uC11C\uB85C \uC544\uBB34\uB7F0
        \uB9D0\uB3C4 \uC787\uC9C0 \uBABB\uD588\uB2E4.)"
      backgroundId: Dating_amuse_night
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uB180\uC774\uACF5\uC6D0 \uB370\uC774\uD2B8\uC758 \uD53C\uB85C\uAC00
        \uBAB0\uB824\uC624\uB294\uC9C0, \uD478\uC559\uC774\uB294 \uCE68\uB300\uC5D0
        \uD138\uC369 \uC8FC\uC800\uC549\uC544 \uAE38\uAC8C \uD55C\uC228\uC744 \uB0B4\uC270\uB2E4.
        \uADF8\uB7EC\uB2E4 \uBB38\uB4DD \uAC89\uC637 \uC8FC\uBA38\uB2C8 \uCABD\uC5D0\uC11C
        \uBB35\uC9C1\uD55C \uC774\uBB3C\uAC10\uC774 \uB290\uAEF4\uC838 \uC190\uC744
        \uC9D1\uC5B4\uB123\uB294\uB2E4.)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC544, \uB9DE\uB2E4, \uC774\uAC70..."
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC8FC\uBA38\uB2C8\uC5D0\uC11C \uC870\uC2EC\uC2A4\uB7FD\uAC8C \uAEBC\uB0B8
        \uAC83\uC740 \uB0AE\uC5D0 \uB864\uB7EC\uCF54\uC2A4\uD130 \uC55E\uC5D0\uC11C
        \uC720\uC6B0\uCE74\uAC00 \uC815\uC2E0\uC5C6\uC5B4\uD558\uB358 \uB098\uC5D0\uAC8C
        \uB9E1\uACBC\uB358 \uBB3C\uAC74, \uC790\uADF8\uB9C8\uD55C '\uBB3C\uACE0\uAE30
        \uD0A4\uB9C1'\uC774\uC5C8\uB2E4.)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC138\uC6D4\uC758 \uD754\uC801\uC774 \uBB3B\uC5B4 \uAD70\uB370\uAD70\uB370
        \uCE60\uC774 \uBC97\uACA8\uC9C0\uACE0 \uB0A1\uC558\uC9C0\uB9CC, \uB3D9\uAE00\uB3D9\uAE00\uD558\uACE0
        \uADC0\uC5EC\uC6B4 \uBAA8\uC591\uC758 \uD30C\uB780 \uBB3C\uACE0\uAE30 \uD615\uD0DC\uB97C
        \uD558\uACE0 \uC788\uB2E4.)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC74C\u2026\u2026 \uB2E4\uC74C\uC5D0 \uB9CC\uB098\uBA74 \uBC14\uB85C
        \uB3CC\uB824\uC918\uC57C\uACA0\uB2E4."
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uD478\uC559\uC774\uB294 \uD0A4\uB9C1\uC744 \uCC45\uC0C1 \uC704\uC5D0
        \uC870\uC2EC\uC2A4\uB7FD\uAC8C \uC62C\uB824\uB450\uACE0 \uBD88\uC744 \uB048\uB2E4.)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
