    gradeChange: 0
    friendshipChange: 0
    completesDate: 0
  - sceneId: 21
    lines:
    - speaker: "\uB098"
      text: "\uC751? \uBB58 \uBD10? \uB098 \uBC29\uAE08 \uBD80\uC5CC\uC5D0\uC11C
        \uBB3C \uB9C8\uC2DC\uACE0 \uC774\uC81C \uB9C9 \uB098\uC624\uB294 \uAE38\uC778\uB370?
        \uD654\uC7A5\uC2E4\uC5D0 \uADC0\uC2E0\uC774\uB77C\uB3C4 \uB098\uC654\uC5B4?
        \uC65C \uADF8\uB807\uAC8C \uB180\uB77C?"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\u2026\u2026\uC9C4\uC9DC? \uC9C4\uC9DC\uB85C \uC544\uBB34\uAC83\uB3C4
        \uBABB \uBCF8 \uAC70\uC57C? \uB0B4 \uD589\uB3D9\uC774\uB77C\uB358\uAC00,
        \uB0B4 \uC190\uC5D0 \uB4E4\uB824 \uC788\uB358 \uAC70\uB77C\uB358\uAC00\u2026\u2026!"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_surprised
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uBB34\uC2A8 \uC18C\uB9AC\uC57C. \uC124\uB9C8 \uD654\uC7A5\uC2E4\uC5D0\uC11C
        \uB0B4 \uBB3C\uAC74 \uD6D4\uCE58\uAE30\uB77C\uB3C4 \uD55C \uAC70\uC57C? \uCE20\uBB34\uAE30
        \uCA29\uC774 \uADF8\uB7F4 \uB9AC\uAC00 \uC5C6\uC796\uC544~"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uC548\uB3C4\uC758 \uD55C\uC228\uC744 \uB0B4\uC26C\uBA70 \uAC00\uC2B4\uC744
        \uC4F8\uC5B4\uB0B4\uB9B0\uB2E4)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uD6C4\uC6B0\uC6B0\u2026\u2026 \uD558\uC544, \uB2E4\uD589\uC774\uB2E4\u2026\u2026.
        \uC544, \uC544\uB2C8! \uB0B4\uAC00 \uC65C \uB3C4\uB451\uC9C8\uC744 \uD574?!
        \uC0AC\uB78C\uC744 \uBB58\uB85C \uBCF4\uACE0!"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_angry
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uD558\uD558, \uC7A5\uB09C\uC774\uC57C. \uC790, \uBAA9\uB9C8\uB974\uC9C0?
        \uBCF4\uB9AC\uCC28\uB77C\uB3C4 \uB9C8\uC154."
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uC73C, \uC751\u2026\u2026. \uACE0\uB9C8\uC6CC."
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uC9C4\uC9DC \uBABB \uBD10\uC11C \uB2E4\uD589\uC774\uB2E4\u2026\u2026
        \uBD24\uC73C\uBA74 \uB098 \uBD80\uB044\uB7EC\uC6CC\uC11C \uC8FD\uC5B4\uBC84\uB838\uC744\uC9C0\uB3C4
        \uBAB0\uB77C\u2026\u2026.)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_default
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uAC04\uB2F4\uC774 \uC11C\uB298\uD588\uB358 \uC21C\uAC04\uC774\uC5C8\uB2E4.
        \uB0B4 \uC5C4\uCCAD\uB09C \uC5F0\uAE30\uB825 \uB355\uBD84\uC5D0 \uCE20\uBB34\uAE30\uC758
        \uC790\uC874\uC2EC\uACFC \uC6B0\uB9AC\uC758 \uC9D1\uB370\uC774\uD2B8\uB294
        \uBB34\uC0AC\uD788 \uC9C0\uCF1C\uC9C8 \uC218 \uC788\uC5C8\uB2E4. \uB2E4\uD589\uC774\uB2E4,
        \uC815\uB9D0\uB85C.)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    hasChoice: 0
