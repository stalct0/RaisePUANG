  m_Script: {fileID: 11500000, guid: a14ba248080591843a816c52cec034f3, type: 3}
  m_Name: Date32
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: Date32
  storyKind: 0
  datingCharacter: 0
  datingLocation: 0
  startSceneId: 0
  scenes:
  - sceneId: 2
    lines:
    - speaker: "\uB098"
      text: "(\uC124\uB9C8 \uB0B4 \uBC29\uC5D0 \uCE20\uBB34\uAE30\uB97C \uCD08\uB300\uD558\uB294
        \uB0A0\uC774 \uC62C \uC904\uC774\uC57C. \uBC29\uC744 \uCE58\uC6B0\uAE34 \uD588\uC9C0\uB9CC
        \uB0A8\uC790 \uD63C\uC790 \uC0AC\uB294 \uC9D1\uC774\uB77C \uD639\uC2DC \uC774\uC0C1\uD55C
        \uB0C4\uC0C8\uB77C\uB3C4 \uB098\uC9C0 \uC54A\uC744\uAE4C \uAC71\uC815\uC774
        \uC55E\uC130\uB2E4.)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uBC29\uC5D0 \uB4E4\uC5B4\uC11C\uBA70 \uD081\uD081\uAC70\uB9AC\uB2E4\uAC00,
        \uC870\uADF8\uB9CC \uBAA9\uC18C\uB9AC\uB85C) \u2026\u2026\uC557, \uD478\uC559
        \uCFE4 \uB0C4\uC0C8\u2026\u2026."
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC5B4? \uCE20\uBB34\uAE30 \uCA29, \uBC29\uAE08 \uBB50\uB77C\uACE0 \uD588\uC5B4?
        \uD639\uC2DC \uD034\uD034\uD55C \uB0C4\uC0C8\uB77C\uB3C4 \uB098?"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uBC14..\uBC14\uCE74\uC7C8\uB098\uC774\uB178..!!? \uB09C\uB370\uBAA8
        \uB098\uC774\uAC70\uB4E0...! \uB0B4..\uB0B4\uAC00 \uC65C \uB2C8 \uBC29 \uB0C4\uC0C8\uB97C
        \uC2E0\uACBD \uC4F0\uB0D0\uACE0!! .. \uADF8\uAC83\uBCF4\uB2E4 \uC190 \uC880
        \uC53B\uC744 \uD14C\uB2C8\uAE4C \uD654\uC7A5\uC2E4 \uC5B4\uB514\uC57C?!"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_angry
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC5B4, \uC800\uAE30 \uBCF5\uB3C4 \uC624\uB978\uCABD\uC5D0..."
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uCE20\uBB34\uAE30\uCA29\uC740 \uB3C4\uB9DD\uCE58\uB4EF\uC774 \uD654\uC7A5\uC2E4\uB85C
        \uB2EC\uB824\uAC14\uB2E4.)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_angry
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uD654\uC7A5\uC2E4\uB85C \uC3D9 \uB4E4\uC5B4\uAC00 \uBC84\uB9B0 \uCE20\uBB34\uAE30.
        \uADF8 \uD2C8\uC0C8\uB85C \uBBFF\uC744 \uC218 \uC5C6\uB294 \uAD11\uACBD\uC774
        \uBCF4\uC600\uB2E4...)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uD654\uC7A5\uC2E4 \uC548 \uC138\uD0C1 \uBC14\uAD6C\uB2C8 \uC55E\uC5D0\uC11C
        \uD478\uC559\uC758 \uD2F0\uC154\uCE20\uB97C \uB4E4\uACE0 \uCF54\uB97C \uD6CC\uCA4D\uC774\uBA70)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\u2026\u2026\uC5ED\uC2DC \uD478\uC559 \uCFE4 \uB0C4\uC0C8\uAC00 \uB098.
        \uD081\uCE74\uD081\uCE74\u2026\u2026 \uD750\uC544\uC544, \uBB54\uAC00 \uC548\uC2EC\uB418\uB294
        \uB0C4\uC0C8\uB784\uAE4C\u2026\u2026. (\uC5BC\uAD74\uC744 \uD2F0\uC154\uCE20\uC5D0
        \uBB3B\uACE0 \uBD80\uBE44\uC801\uAC70\uB9B0\uB2E4)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uBB3C\uCEF5\uC744 \uB4E4\uBA70)\uCE20\uBB34\uAE30\uCA29, \uBCF4\uB9AC\uCC28
        \uB9C8\uC2E4\uB798?..\uC5B4\uB808..?"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uD760\uCE6B\uD558\uBA70 \uACE0\uAC1C\uB97C \uBC88\uCA4D \uB4E0\uB2E4.
        \uB098\uC640 \uB208\uC774 \uB531 \uB9C8\uC8FC\uCE5C\uB2E4)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uCE20\uBB34\uAE30\uC758 \uC190\uC5D0\uB294 \uC5EC\uC804\uD788 \uB0B4
        \uD2F0\uC154\uCE20\uAC00 \uB4E4\uB824 \uC788\uC5C8\uB2E4. \uC815\uC801\uC774
        \uD750\uB974\uACE0, \uCE20\uBB34\uAE30\uC758 \uC5BC\uAD74\uC774 \uC21C\uC2DD\uAC04\uC5D0
        \uD3ED\uBC1C\uD560 \uAC83\uCC98\uB7FC \uBD89\uC5B4\uC84C\uB2E4.)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    hasChoice: 1
    choiceTextA: "(\uBD24\uB2E4\uACE0 \uC815\uC9C1\uD558\uAC8C, \uC544\uB2C8 \uC2E4\uC218\uB85C
      \uACE0\uBC31\uD55C\uB2E4)"
    nextSceneA: 20
    affectionA: 0
    girlfriendA: 0
    choiceTextB: "(\uC5B4\uC124\uD508 \uAC70\uC9D3\uB9D0\uB85C \uC5B4\uB5BB\uAC8C\uB4E0
      \uB118\uC5B4\uAC00 \uBCF8\uB2E4)"
    nextSceneB: 21
    affectionB: 0
    girlfriendB: 0
    choiceTextC: 
    nextSceneC: -1
    affectionC: 0
    girlfriendC: 0
    moneyChange: 0
    conditionChange: 0
    gradeChange: 0
    friendshipChange: 0
    completesDate: 0
  - sceneId: 20
    lines:
    - speaker: "\uB098"
      text: "(\uB2F9\uD669\uD574\uC11C \uC190\uC0AC\uB798\uB97C \uCE58\uBA70) \uC544,
        \uC548 \uBD24\uC5B4! \uC804\uD600 \uC548 \uBD24\uC5B4! \uCE20\uBB34\uAE30
        \uCA29\uC774 \uB0B4 \uD2F0\uC154\uCE20\uB97C \uB4E4\uACE0 \uD081\uCE74\uD081\uCE74\uD558\uBA74\uC11C
        \uC5BC\uAD74\uC744 \uBD80\uBE44\uC801\uAC70\uB9AC\uB294 \uBAA8\uC2B5 \uAC19\uC740
        \uAC70, \uC815\uB9D0 \uB2E8 1\uCD08\uB3C4 \uC548 \uBD24\uB2E4\uB2C8\uAE4C?!"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uCF70\uACFC\uAD11- \uBA38\uB9BF\uC18D\uC774 \uC0C8\uD558\uC598\uC9C4
        \uD45C\uC815) \u2026\u2026\uB2E4 \uB9D0\uD588\uC796\uC544, \uC774 \uBA4D\uCCAD\uC774
        \uD478\uC559 \uCFE0\uC6B0\uC6B0\uC6B4..!!"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_angry
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "\uC544\uC557! \uB0B4 \uC785 \uBC29\uC815\uC774\u2026\u2026! \uBBF8\uC548,
        \uB2E4 \uBD24\uC5B4!.. \uC544\uB2C8.. \uC548\uBD24\uC5B4!"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uBD80\uB044\uB7EC\uC6C0\uACFC \uC218\uCE58\uC2EC\uC774 \uD3ED\uBC1C\uD574
        \uC8FC\uBA39\uC73C\uB85C \uB0B4 \uAC00\uC2B4\uC744 \uD321\uD321 \uB54C\uB9B0\uB2E4)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_angry
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "\uC73C\uC544\uC544\uC544! \uC8FD\uC5B4! \uADF8\uB0E5 \uC8FD\uC5B4\uBC84\uB824!
        \uC65C \uADF8\uB7F0 \uAC78 \uBCF4\uACE0 \uC788\uB294 \uAC74\uB370!!  \uC5E3\uCE58!!
        \uD5E8\uD0C0\uC774! \uB77C\uB178\uBCA8 \uC8FC\uC778\uACF5!!"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_angry
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uBBF8\uC548\uD574! \uD558\uC9C0\uB9CC \uB108\uBB34 \uADC0\uC5EC\uC6CC\uC11C
        \uADF8\uB9CC\u2026\u2026!"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uADC0\uC5EC\uC6E0\uB2E4\uB294 \uB9D0\uC5D0 \uBA48\uCE6B\uD558\uC9C0\uB9CC,
        \uC774\uBBF8 \uAC89\uC7A1\uC744 \uC218 \uC5C6\uC774 \uBE68\uAC1C\uC9C4 \uC5BC\uAD74\uB85C
        \uBB38\uC73C\uB85C \uB2EC\uB824\uAC04\uB2E4)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "\uC2DC\uB044\uB7EC\uC6CC! \uBAB0\uB77C, \uB098 \uC9D1\uC5D0 \uAC08 \uAC70\uC57C!
        \uC624\uB298 \uC77C\uC740 \uD3C9\uC0DD \uAE30\uC5B5\uC5D0\uC11C \uC9C0\uC6CC\uBC84\uB824,
        \uC54C\uC558\uC5B4?! \uCF85!!"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uD604\uAD00\uBB38\uC774 \uBD80\uC11C\uC838\uB77C \uB2EB\uD788\uACE0,
        \uB098\uB294 \uD63C\uC790 \uB0A8\uACA8\uC84C\uB2E4. \uAC70\uC9D3\uB9D0\uC744
        \uD558\uB824\uB2E4 \uC5ED\uB300\uAE09 \uB9D0\uC2E4\uC218\uB97C \uC800\uC9C0\uB978
        \uB098 \uC790\uC2E0\uC744 \uB54C\uB9AC\uACE0 \uC2F6\uC5C8\uB2E4. \uC624\uB298
        \uB370\uC774\uD2B8\uB294\u2026\u2026 \uC644\uC804\uD788 \uB9DD\uD588\uB2E4.)"
      backgroundId: Dating_home
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    hasChoice: 0
    choiceTextA: 
    nextSceneA: -1
    affectionA: 0
    girlfriendA: 0
    choiceTextB: 
    nextSceneB: -1
    affectionB: 0
    girlfriendB: 0
    choiceTextC: 
    nextSceneC: -1
