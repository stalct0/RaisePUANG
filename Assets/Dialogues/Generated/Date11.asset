  m_Script: {fileID: 11500000, guid: a14ba248080591843a816c52cec034f3, type: 3}
  m_Name: Date11
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: Date11
  storyKind: 0
  datingCharacter: 0
  datingLocation: 0
  startSceneId: 0
  scenes:
  - sceneId: 0
    lines:
    - speaker: "\uB098"
      text: "(.....\uD5C9! \uC800, \uC800\uAE30 \uAC78\uC5B4\uC624\uB294 \uBBF8\uC18C\uB140....
        \uC124\uB9C8 \uC720\uC6B0\uCE74 \uC528?! \uBBF8\uCCE4\uB2E4, \uC624\uB298
        \uC2A4\uD0C0\uC77C \uB208\uC774 \uBD80\uC154\uC11C \uBABB \uCCD0\uB2E4\uBCF4\uACA0\uC5B4!!
        \uC644\uC804 \uC5EC\uC2E0 \uADF8\uC790\uCCB4\uC796\uC544..! \uC2EC\uC7A5\uC774
        \uB450\uADFC\uAC70\uB9B0\uB2E4\uAD6C..!)"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uC544, \uD478\uC559 \uCFE4! \uB9CE\uC774 \uAE30\uB2E4\uB838\uC9C0?
        \uC624\uB298 \uC601\uD654 \uBCF4\uB7EC \uC628\uB2E4\uACE0 \uB098\uB984 \uC2E0\uACBD
        \uC880 \uC4F0\uACE0 \uB098\uC654\uB294\uB370\u2026\u2026 \uD5E4\uD5E4..."
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "(\uC720\uC6B0\uCE74\uB294 \uBD80\uB044\uB7EC\uC6B4 \uB4EF \uC6D0\uD53C\uC2A4
        \uC790\uB77D\uC744 \uB9CC\uC9C0\uC791\uAC70\uB9AC\uB354\uB2C8, \uD478\uC559\uC774\uC758
        \uB208\uC744 \uBE64\uD788 \uBC14\uB77C\uBCF4\uBA70 \uC5BC\uAD74\uC744 \uC0B4\uC9DD
        \uB4E4\uC774\uBBFC\uB2E4.)"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uC788\uC796\uC544, \uD478\uC559 \uCFE4. \uB098\u2026\u2026 \uC624\uB298
        \uD3C9\uC18C\uB791 \uB2EC\uB77C\uC9C4 \uAC70 \uC5C6\uC5B4? \uB9DE\uCDB0\uBD10!"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC557, \uADF8, \uADF8\uAC74 \uB2F9\uC5F0\uD788 \uC637\u2026\u2026!"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_smile
      leftAppearanceId: 
      rightAppearanceId: 
    hasChoice: 1
    choiceTextA: "\uC55E\uBA38\uB9AC \uC798\uB790\uB124?"
    nextSceneA: 10
    affectionA: 0
    girlfriendA: 0
    choiceTextB: "\uC544\uD558! \uBCFC\uD130\uCE58 \uD588\uAD6C\uB098?"
    nextSceneB: 10
    affectionB: 0
    girlfriendB: 0
    choiceTextC: "\uC74C... \uC544\uC774\uC100\uB3C4\uC6B0\uB77C\uB3C4 \uD588\uB098?"
    nextSceneC: 20
    affectionC: 0
    girlfriendC: 0
    moneyChange: 0
    conditionChange: 0
    gradeChange: 0
    friendshipChange: 0
    completesDate: 0
  - sceneId: 10
    lines:
    - speaker: "\uB098"
      text: "(\u2026\u2026\uC5B4\uC774!!! '\uC637'\uC774 \uC5C6\uC796\uC544, '\uC637'\uC774!!!
        \uB204\uAC00 \uBD10\uB3C4 \uD654\uC0AC\uD55C \uC6D0\uD53C\uC2A4\uB97C \uC785\uACE0
        \uB098\uC654\uB294\uB370 \uC65C \uC120\uD0DD\uC9C0\uC5D0\uB294 \uC774\uB534
        \uAC83\uBC16\uC5D0 \uC5C6\uB294 \uAC74\uB370!! \uCE58\uD06C\uC1FC!!)"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uC880 \uB354 \uC790\uC138\uD788 \uBD10\uC918.. \uD478\uC559\uCFE4.."
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_default
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC544\uB2C8, \uC880 \uB354 \uC790\uC138\uD788 \uBCF4\uB77C\uB2C8\u2026\u2026
        \uB0B4 \uB208\uC5D4 \uBA87\uBD84 \uC804\uC774\uB791 \uC644\uC804\uD788 \uB611\uAC19\uC740
        \uC77C\uB7EC\uC2A4\uD2B8\uC778\uB370 \uC5EC\uAE30\uC11C \uC5B4\uB5BB\uAC8C 
        \uC54C\uC544\uCC44\uB77C\uB294 \uAC70\uC57C! \uC5B4\uC774! \uB3CB\uBCF4\uAE30\uB85C
        \uD53D\uC140\uC774\uB77C\uB3C4 \uD22C\uC2DC\uD574 \uBCF4\uB77C\uB294 \uC18C\uB9AC\uC57C?"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uC774, \uC77C\uB7EC\uC2A4\uD2B8\u2026\u2026? \uD53D\uC140\uC774\uB77C\uB2C8?
        \uD478\uC559\uCFE4.. \uAC11\uC790\uAE30 \uBB34\uC2A8 \uC18C\uB9AC\uB97C \uD558\uB294
        \uAC70\uC57C..?"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_angry
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC73D.. \uC2E4\uC218\uD588\uB2E4..! \uBCF8\uC2EC\uC774 \uD280\uC5B4\uB098\uC640
        \uBC84\uB838\uC5B4! \uC774\uC81C \uBB50\uB77C \uB458\uB7EC\uB300\uC57C\uD558\uC9C0..?)"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC544, \uC544\uD558\uD558! \uADF8, \uADF8\uB7EC\uB2C8\uAE4C \uB0B4
        \uB9D0\uC740\u2026\u2026 \uC720\uC6B0\uCE74\uCA29\uC758 \uBBF8\uBAA8\uAC00
        \uB108\uBB34 \uBE44\uD604\uC2E4\uC801\uC774\uB77C \uB9C8\uCE58 \uD55C \uD3ED\uC758
        '\uC77C\uB7EC\uC2A4\uD2B8' \uAC19\uC544\uC11C \uB9D0\uC774\uC57C.. \uD558\uD558\uD558.."
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uC73C, \uC751\u2026\u2026? \uACE0\uB9D9\uAE34 \uD55C\uB370 \uD478\uC559\uCFE4,
        \uC624\uB298\uB530\uB77C \uD45C\uD604\uC774 \uB418\uAC8C \uB3C5\uD2B9\uD558\uB124\u2026\u2026."
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_default
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\u2026\u2026\uC870\uC84C\uB2E4. \uC720\uC6B0\uCE74\uCA29\uC758 \uC8FC\uBCC0
        \uACF5\uAE30\uAC00 \uC774\uC0C1\uD574..! \uBE44\uC0C1\uC774\uB2E4..!)"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC120\uD0DD\uC9C0 \uC5B5\uAE4C\uB85C \uC2DC\uC791\uBD80\uD130 \uC0BC\uCC9C\uD3EC\uB85C
        \uBE60\uC9C0\uB354\uB2C8, \uAE30\uAECF \uACE0\uB978 \uC601\uD654\uB9C8\uC800\uB3C4
        \uC608\uC220\uBCD1\uC5D0 \uAC78\uB9B0 \uC9C0\uB8E8\uD568\uC758 \uADF9\uCE58\uC778
        \uC791\uD488\uC774\uC5C8\uB2E4.)"
      backgroundId: Dating_theater_inside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uD31D\uCF58\uB9CC \uAE30\uACC4\uC801\uC73C\uB85C \uBA39\uACE0\uC788\uB358\uC9C0
        \uC5B4\uC5B8 30\uBD84 \uC606\uC790\uB9AC\uC758 \uC720\uC6B0\uCE74 \uC528\uB294
        \uC9C0\uB8E8\uD568\uC744 \uCC38\uC9C0 \uBABB\uD558\uACE0 '\uC314\uADFC\uC314\uADFC\u2026\u2026'
        \uC228\uC18C\uB9AC\uB97C \uB0B4\uBA70 \uAE4A\uC740 \uC7A0\uC5D0 \uBE60\uC838\uB4E4\uACE0
        \uB9D0\uC558\uB2E4.)"
      backgroundId: Dating_theater_inside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uACB0\uAD6D \uADF9\uC7A5\uC5D0 \uBD88\uC774 \uCF1C\uC9C8 \uB54C\uAE4C\uC9C0
        \uC720\uC6B0\uCE74 \uC528\uB294 \uAFC0\uC7A0\uC744 \uC7A4\uACE0, \uB098\uB294
        \uB098\uB300\uB85C \uC5BC\uC5B4\uBD99\uC5B4 \uC788\uB2E4\uAC00 \uC815\uC2E0\uC744
        \uCC28\uB824\uBCF4\uB2C8 \uB370\uC774\uD2B8\uAC00 \uD1B5\uC9F8\uB85C \uC2A4\uD0B5\uB418\uC5B4
        \uB05D\uB098 \uC788\uC5C8\uB2E4.)"
      backgroundId: Dating_theater_inside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    hasChoice: 0
    choiceTextA: 
    nextSceneA: -1
    affectionA: 0
    girlfriendA: 0
    choiceTextB: 
    nextSceneB: -1
    affectionB: 0
    girlfriendB: 0
    choiceTextC: 
    nextSceneC: -1
