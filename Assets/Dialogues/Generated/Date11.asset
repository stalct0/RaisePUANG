    completesDate: 1
  - sceneId: 20
    lines:
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uC5ED\uC2DC \uD478\uC559\uCFE4\uC740 \uC54C\uC544\uCC4C \uAC70\uB77C\uACE0
        \uC0DD\uAC01\uD588\uC5B4..! \uC5ED\uC2DC \uC138\uC2EC\uD558\uB2E4\uB2C8\uAE4C..!"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\u2026\u2026\uB294 \uC0AC\uC2E4 \uCC0D\uC740 \uAC70\uC9C0\uB9CC \uB300\uC131\uACF5\uC774\uB2E4!)
        \uB2F9\uC5F0\uD558\uC9C0! \uB0B4 \uB208\uC740 \uC18D\uC5EC\uB3C4 \uC720\uC6B0\uCE74\uCA29\uC744
        \uD5A5\uD55C \uB9C8\uC74C\uC740 \uC18D\uC77C \uC218 \uC5C6\uC9C0..!"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uC720\uC6B0\uCE74"
      text: "\uC5D0\uC5E3, \uC815\uB9D0? \uADF8\uB807\uAC8C \uC138\uC2EC\uD558\uAC8C
        \uBD10\uC92C\uB2E4\uB2C8 \uC870\uAE08 \uAC10\uB3D9\uC778\uAC78?"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: Dating_Yuuka_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC644\uBCBD\uD558\uB2E4. \uC644\uBCBD\uD574! \uC774\uBC88 \uC774\uBCA4\uD2B8\uB294
        \uADF8\uC57C\uB9D0\uB85C \uB300\uC131\uACF5\uC774\uB2E4!)"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC774\uAC8C \uC815\uB2F5\uC77C \uC904\uC774\uC57C! \uB355\uBD84\uC5D0
        \uC720\uC6B0\uCE74 \uC528\uC758 \uD638\uAC10\uB3C4\uB294 \uADF8 \uC790\uB9AC\uC5D0\uC11C
        \uC218\uC9C1 \uC0C1\uC2B9!!)"
      backgroundId: Dating_theater_outside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC601\uD654 \uB0B4\uC6A9\uC740 \uC194\uC9C1\uD788 \uD558\uB098\uB3C4
        \uAE30\uC5B5 \uC548 \uB098\uC9C0\uB9CC \uBB34\uC2A8 \uC0C1\uAD00\uC778\uAC00?
        \uB0B4 \uC606\uC790\uB9AC\uC758 \uCD08\uBBF8\uC18C\uB140\uAC00 \uCFE0\uD0A4
        \uC601\uC0C1\uBCF4\uB2E4 \uB2EC\uB2EC\uD55C \uBBF8\uC18C\uB97C \uC9C0\uC73C\uBA70
        \uB098\uB97C \uBC14\uB77C\uBCF4\uACE0 \uC788\uB294\uB370!(\uC5B4\uC774!))"
      backgroundId: Dating_theater_inside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC88B\uC544, \uC774 \uAE30\uC138\uB97C \uBAB0\uC544 \uB2E4\uC74C \uB8E8\uD2B8\uAE4C\uC9C0
        \uC804\uB825 \uC9C8\uC8FC\uB2E4!)"
      backgroundId: Dating_theater_inside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC5B4\uB450\uCEF4\uCEF4\uD55C \uC0C1\uC601\uAD00 \uC548\uC5D0\uC11C
        \uC6B0\uB9AC\uB294 \uADF8\uC57C\uB9D0\uB85C \uBA54\uC778 \uD788\uB85C\uC778\uACFC
        \uB0A8\uC790 \uC8FC\uC778\uACF5 \uADF8 \uC790\uCCB4\uC600\uB2E4.)"
      backgroundId: Dating_theater_inside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC601\uD654\uAC00 \uC2DC\uC791\uB418\uC790\uB9C8\uC790 \uC720\uC6B0\uCE74
        \uCA29\uC740 \uC740\uADFC\uC2AC\uCA4D \uB0B4 \uC5B4\uAE68 \uCABD\uC73C\uB85C
        \uBAB8\uC744 \uBC00\uCC29\uD574 \uC654\uACE0, \uBB34\uC11C\uC6B4 \uC7A5\uBA74\uC5D0\uC11C
        \uB098\uB294 \uC720\uC6B0\uCE74\uC9F1\uC758 \uC190\uC744 \uD3EC\uAC1C\uC5B4
        \uAC00\uBCCD\uAC8C \uC7A1\uC558\uB2E4.)"
      backgroundId: Dating_theater_inside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uADF8 \uC774\uD6C4\uB85C \uC774\uB7F0\uC800\uB7F0 \uC77C\uC774 \uC788\uC5C8\uC9C0\uB9CC
        \uC601\uD654\uAD00 \uB370\uC774\uD2B8\uB294 \uC131\uACF5\uC801\uC73C\uB85C
        \uB9C8\uBB34\uB9AC\uB410\uB2E4.)"
      backgroundId: Dating_theater_inside
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    hasChoice: 0
