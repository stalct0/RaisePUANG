    lines:
    - speaker: "\uD478\uC559"
      text: "\uC624\uB298 \uC2DC\uAC04 \uAD1C\uCC2E\uC544?"
    - speaker: "\uC18C\uAFC9\uCE5C\uAD6C"
      text: "\uAC11\uC790\uAE30 \uC65C? \uB610 \uC774\uC0C1\uD55C \uAC70 \uD558\uB824\uB294
