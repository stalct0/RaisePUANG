  - sceneId: 5
    lines:
    - speaker: "\uC18C\uAFC9\uCE5C\uAD6C"
      text: "\uADF8\uB798. \uB2E4\uC74C\uC5D4 \uC9C4\uC9DC\uB85C \uACC4\uD68D\uD558\uACE0
        \uBD88\uB7EC."
    - speaker: System
