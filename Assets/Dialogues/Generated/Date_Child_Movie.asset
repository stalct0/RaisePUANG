  - sceneId: 1
    lines:
    - speaker: "\uC18C\uAFC9\uCE5C\uAD6C"
      text: "\uC601\uD654? \uB098\uC058\uC9C0 \uC54A\uC740\uB370."
    - speaker: "\uD478\uC559"
      text: "\uADF8\uB7FC \uB0B4\uAC00 \uC608\uB9E4\uD560\uAC8C."
    hasChoice: 1
    choiceTextA: "\uD31D\uCF58\uB3C4 \uC0AC\uC900\uB2E4"
    nextSceneA: 3
    affectionA: 1
    choiceTextB: "\uD31D\uCF58\uC740 \uAC01\uC790 \uC0B0\uB2E4"
    nextSceneB: 4
    affectionB: -1
