    friendshipChange: 0
    completesDate: 1
  - sceneId: 4
    lines:
    - speaker: "\uC18C\uAFC9\uCE5C\uAD6C"
      text: "\uAC01\uC790? \uADF8\uB798 \uBB50... \uD569\uB9AC\uC801\uC774\uAE34
        \uD558\uB124."
    - speaker: System
      text: "\uC624\uB298 \uB370\uC774\uD2B8\uB294 \uBB34\uB09C\uD558\uAC8C \uC9C0\uB098\uAC04
        \uAC83 \uAC19\uB2E4."
