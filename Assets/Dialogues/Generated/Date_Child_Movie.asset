    friendshipChange: 0
    completesDate: 0
  - sceneId: 2
    lines:
    - speaker: "\uC18C\uAFC9\uCE5C\uAD6C"
      text: "\uBB50\uC57C, \uBD80\uB978 \uC0AC\uB78C\uC774 \uC9D1\uC5D0 \uC788\uC790\uACE0
        \uD558\uBA74 \uC5B4\uB5A1\uD574."
    hasChoice: 1
    choiceTextA: "\uBBF8\uC548\uD558\uB2E4 \uD558\uACE0 \uB2E4\uC2DC \uC601\uD654
      \uC81C\uC548"
    nextSceneA: 1
    affectionA: 1
    choiceTextB: "\uADF8\uB0E5 \uB2E4\uC74C\uC5D0 \uBCF4\uC790"
    nextSceneB: 5
    affectionB: -1
    moneyChange: 0
    conditionChange: 0
    gradeChange: 0
    friendshipChange: 0
    completesDate: 0
  - sceneId: 3
    lines:
    - speaker: "\uC18C\uAFC9\uCE5C\uAD6C"
      text: "\uC624, \uC6EC\uC77C\uB85C \uC13C\uC2A4 \uC788\uB124."
    - speaker: "\uD478\uC559"
      text: "\uC624\uB298\uC740 \uB0B4\uAC00 \uC880 \uC900\uBE44\uD588\uB2E4."
    - speaker: System
      text: "\uC624\uB298 \uB370\uC774\uD2B8\uB294 \uAF64 \uC131\uACF5\uC801\uC774\uC5C8\uB358
        \uAC83 \uAC19\uB2E4."
    hasChoice: 0
    choiceTextA: 
    nextSceneA: -1
    affectionA: 0
    choiceTextB: 
    nextSceneB: -1
    affectionB: 0
    moneyChange: 0
    conditionChange: 0
