%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a14ba248080591843a816c52cec034f3, type: 3}
  m_Name: Date33
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: Date33
  storyKind: 0
  datingCharacter: 0
  datingLocation: 0
  startSceneId: 0
  scenes:
  - sceneId: 3
    lines:
    - speaker: 
      text: "(\uACBD\uCF8C\uD55C \uBC84\uC2A4\uD0B9 \uC74C\uC545 \uC18C\uB9AC\uC640
        \uC0AC\uB78C\uB4E4\uC758 \uC6C5\uC131\uAC70\uB9BC\uC774 \uBC30\uACBD\uC73C\uB85C
        \uAE54\uB9B0\uB2E4.)"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uB9D1\uC740 \uB0AE\uC758 \uB0A8\uC0B0\uD0C0\uC6CC. \uD478\uB978 \uD558\uB298
        \uC544\uB798\uC11C \uC57C\uC678 \uC74C\uC545 \uACF5\uC5F0\uC744 \uBCF4\uBA70
        \uCE20\uBB34\uAE30\uC640 \uB098\uB780\uD788 \uAC77\uACE0 \uC788\uC5C8\uB2E4.
        \uC2E0\uB098\uB294 \uB9AC\uB4EC\uC5D0 \uB9DE\uCDB0 \uCE20\uBB34\uAE30\uB3C4
        \uB0B4\uC2EC \uC2E0\uC774 \uB0AC\uB294\uC9C0 \uAC00\uBCBC\uC6B4 \uBC1C\uAC78\uC74C\uC73C\uB85C
        \uC2A4\uD15D\uC744 \uBC1F\uB358 \uADF8\uB54C\uC600\uB2E4.)"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uD589\uC778"
      text: "\uC557, \uC8C4\uC1A1\uD569\uB2C8\uB2E4! (\uCF85, \uBD80\uB52A\uD788\uB294
        \uC18C\uB9AC)"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uAE85\u2026\u2026?!"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_surprised
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uC911\uC2EC\uC744 \uC783\uACE0 \uB4A4\uB85C \uB118\uC5B4\uC9C0\uB824
        \uD55C\uB2E4)"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_surprised
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uCE20\uBB34\uAE30 \uCA29..! \uC544\uBD80\uB098\uC774..!"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uD478\uC559\uCFE4\uC740 \uCE20\uBB34\uAE30\uCA29 \uB4A4\uC5D0\uC11C
        \uB2E8\uB2E8\uD558\uAC8C \uAC10\uC2F8 \uC548\uB294\uB2E4.)"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uBCF8\uC758 \uC544\uB2C8\uAC8C \uC644\uBCBD\uD55C \uBC31\uD5C8\uADF8
        \uD615\uD0DC\uAC00 \uB418\uC5B4\uBC84\uB9B0 \uC21C\uAC04, \uC6B0\uB9AC \uB450
        \uC0AC\uB78C\uC758 \uC2DC\uAC04\uC774 \uBA48\uCD98 \uB4EF\uD588\uB2E4.)"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uD478\uC559\uC758 \uD488\uC5D0 \uC548\uAE34 \uCC44 \uC228\uC744 \uB4E4\uC774\uCF1C\uBA70)
        \u2026\u2026\uC557."
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uADC0 \uBC14\uB85C \uC606\uC5D0\uC11C \uC870\uC2EC\uC2A4\uB7FD\uAC8C)
        \uD6C4\uC6B0\u2026\u2026 \uC694\uCE87\uD0C0... \uC548 \uB2E4\uCCE4\uC5B4,
        \uCE20\uBB34\uAE30 \uCA29?"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uC2EC\uC7A5\uC774 \uD130\uC9C8 \uB4EF \uCFF5\uCF85\uAC70\uB9AC\uB294
        \uAC8C \uC628\uBAB8\uC73C\uB85C \uB290\uAEF4\uC9C4\uB2E4.)\uC73C, \uC751\u2026\u2026
        \uB2E4, \uB2E4\uCE58\uC9C4 \uC54A\uC558\uB294\uB370\u2026\u2026 \uC800\uAE30,
        \uD478\uC559 \uCFE4\u2026\u2026?"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC5B4? \uC544, \uACE0\uBA58!(\uD669\uAE09\uD788 \uD314\uC744 \uD480\uB824\uACE0
        \uD55C\uB2E4)"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uB0B4 \uC637\uC18C\uB9E4\uB97C \uAFB9 \uC7A1\uC73C\uBA70) \uC544,
        \uC544\uB2C8! \uB193\uC73C\uB77C\uB294 \uAC74 \uC544\uB2C8\uACE0\u2026\u2026
        \uADF8\uB7EC\uB2C8\uAE4C\u2026\u2026 \uADF8, \uACE0\uB9C8\uC6CC. (\uACE0\uAC1C\uB97C
        \uD479 \uC219\uC774\uBA70 \uC6C5\uC5BC\uAC70\uB9B0\uB2E4) \uB124 \uD488\u2026\u2026
        \uB418\uAC8C \uB530\uB73B\uD558\uB124."
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: 
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uC794\uC794\uD55C \uD074\uB798\uC2DD \uC7AC\uC988 \uC74C\uC545\uACFC
        \uC640\uC778\uC794\uC774 \uBD80\uB52A\uD788\uB294 \uCC59- \uC18C\uB9AC\uAC00
        \uB4E4\uB9B0\uB2E4.)"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uC5B4\uB290\uB367 \uBC24\uC774 \uCC3E\uC544\uC624\uACE0, \uC6B0\uB9AC\uB294
        \uC740\uC740\uD55C \uC870\uBA85\uC774 \uBC1D\uD600\uC9C4 \uC640\uC778 \uD398\uC5B4\uB85C
        \uC790\uB9AC\uB97C \uC62E\uACBC\uB2E4.)"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uBD89\uC740 \uC640\uC778\uC774 \uB2F4\uAE34 \uC794\uC744 \uC55E\uC5D0
        \uB450\uACE0, \uCE20\uBB34\uAE30\uB294 \uB0AE\uC5D0 \uC788\uC5C8\uB358 \uC77C
        \uB54C\uBB38\uC778\uC9C0 \uC720\uB3C5 \uC218\uC90D\uC740 \uD45C\uC815\uC73C\uB85C
        \uC640\uC778\uB9CC \uD640\uC9DD\uC774\uACE0 \uC788\uC5C8\uB2E4.)"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC9C0\uAE08\uC774 \uC544\uB2C8\uBA74 \uC548 \uB41C\uB2E4\uB294 \uC0DD\uAC01\uC774
        \uB4E4\uC5C8\uB2E4. \uB098\uB294 \uC2EC\uD638\uD761\uC744 \uD558\uACE0, \uCE20\uBB34\uAE30\uC758
        \uC190\uC744 \uC0B4\uBA70\uC2DC \uC950\uC5C8\uB2E4.)"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "(\uB180\uB77C \uB208\uC744 \uB3D9\uADF8\uB797\uAC8C \uB728\uBA70) \u2026\u2026\uD478\uC559
        \uCFE4? \uAC11\uC790\uAE30 \uC65C \uADF8\uB798? \uCDE8\uD588\uC5B4?"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_surprised
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uCE20\uBB34\uAE30 \uCA29. \uC640\uC778\uC5D0 \uCDE8\uD55C \uAC8C \uC544\uB2C8\uB77C,
        \uB124 \uB208\uB3D9\uC790\uC5D0 \uCDE8\uD55C \uAC83 \uAC19\uC544."
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uD558, \uD558\uC544?! \uAC11\uC790\uAE30 \uBB34\uC2A8 \uB9D0\uB3C4
        \uC548 \uB418\uB294 \uB2ED\uC0B4 \uB3CB\uB294 \uBA58\uD2B8\uB97C\u2026\u2026!"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC7A5\uB09C \uC544\uB2C8\uC57C. \uC544\uAE4C \uB0A8\uC0B0\uC5D0\uC11C
        \uB110 \uC548\uC558\uC744 \uB54C \uD655\uC2E4\uD788 \uC54C\uC558\uC5B4."
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "\uB09C \uD3C9\uC0DD \uB124 \uC606\uC5D0\uC11C, \uB110 \uC9C0\uCF1C\uC8FC\uACE0
        \uC2F6\uC5B4."
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "\uCE20\uBB34\uAE30 \uCA29, \uB098\uB791 \uD3C9\uC0DD \uD568\uAED8\uD574
        \uC904\uB798? \uB0B4 \uC601\uC6D0\uD55C \uC0AC\uB791\uC774 \uB418\uC5B4\uC918."
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\u2026\u2026\uC601\uC6D0\uC774\uB77C\uB2C8, \uD478\uC559 \uCFE4\uC740
        \uC9C4\uC9DC \uBC14\uBCF4\uC57C. \uADF8\uB7F0 \uBD80\uB044\uB7EC\uC6B4 \uB9D0\uC744
        \uC544\uBB34\uB807\uC9C0\uB3C4 \uC54A\uAC8C \uD558\uACE0\u2026\u2026."
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_embarrassed
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uC9C4\uC2EC\uC774\uC57C. \uC9C4\uC2EC\uC73C\uB85C \uB110 \uC88B\uC544\uD574,
        \uCE20\uBB34\uAE30."
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\u2026\u2026\uD765, \uADF8\uB807\uAC8C\uAE4C\uC9C0 \uC560\uC6D0\uD55C\uB2E4\uBA74
        \uC5B4\uCA54 \uC218 \uC5C6\uB124. \uADC0\uCC2E\uACA0\uC9C0\uB9CC\u2026\u2026
        \uD2B9\uBCC4\uD788 \uBC1B\uC544\uC904\uAC8C."
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_smile
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "\uD63C\uB610..?"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uCE20\uBB34\uAE30"
      text: "\uC751. \uB098\uB3C4 \uC601\uC6D0\uD788 \uB124 \uACC1\uC5D0 \uC788\uC744
        \uD14C\uB2C8\uAE4C\u2026\u2026 \uBC14\uB78C\uD53C\uC6B0\uBA74 \uC808\uB300
        \uC6A9\uC11C \uC548 \uD560 \uD14C\uB2C8\uAE4C \uB9D0\uC57C!"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: Dating_Tsumugi_default
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: 
      text: "(\uC740\uC740\uD55C \uC870\uBA85 \uC544\uB798, \uCE20\uBB34\uAE30\uC758
        \uB2EC\uCF64\uD55C \uACE0\uBC31 \uC218\uB77D\uACFC \uD568\uAED8 \uC6B0\uB9AC\uC758
        \uC785\uC220\uC774 \uCC9C\uCC9C\uD788 \uACB9\uCCD0\uC84C\uB2E4. \uAE38\uACE0
        \uAE38\uC5C8\uB358 \uCE24\uB370\uB808 \uCE20\uBB34\uAE30 \uCA29\uACFC\uC758
        \uBC00\uB2F9 \uB05D\uC5D0, \uB9C8\uCE68\uB0B4 \uD574\uD53C\uC5D4\uB529\uC758
        \uB9C9\uC774 \uC62C\uB790\uB2E4.)"
      backgroundId: Dating_namsan
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    hasChoice: 0
