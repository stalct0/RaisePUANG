  datingLocation: 0
  startSceneId: 0
  scenes:
  - sceneId: 1
    lines:
    - speaker: "\uB098"
      text: "(\uC804\uCCA0 \uC5ED\uCC29 \uB54C\uBB38\uC5D0 \uC57D\uC18D\uC2DC\uAC04\uC5D0
        \uCD09\uBC15\uD558\uAC8C \uB3C4\uCC29\uD55C\uB2E4.)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\u2026\u2026\uD5C9 \uC800, \uC800\uAE30 \uBCA4\uCE58\uC5D0 \uC549\uC544\uC11C
        \uC2DC\uACC4\uB97C \uBCF4\uACE0\uC788\uB294 \uBBF8\uC18C\uB140\u2026 \uC124\uB9C8
        \uBBF8\uC694\uCF54\uC528 ?! \uBBF8\uCCE4\uB2E4, \uC624\uB298 \uC2A4\uD0C0\uC77C
        \uB208\uC774 \uBD80\uC154\uC11C \uBABB\uCCD0\uB2E4 \uBCF4\uACA0\uC5B4!! \uC644\uC804
        \uC5EC\uC2E0 \uADF8\uC790\uCCB4 \uC796\uC544..! \uC2EC\uC7A5\uC774 \uB450\uADFC\uAC70\uB9B0\uB2E4\uAD6C..!)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    hasChoice: 1
    choiceTextA: "\uC0AC\uC2E4\uB300\uB85C \uB9D0\uD55C\uB2E4."
    nextSceneA: 10
    affectionA: 0
    girlfriendA: 0
    choiceTextB: "\uAC70\uC9D3\uB9D0\uC744 \uD55C\uB2E4."
    nextSceneB: 11
    affectionB: 0
    girlfriendB: 0
    choiceTextC: 
    nextSceneC: -1
    affectionC: 0
    girlfriendC: 0
    moneyChange: 0
    conditionChange: 0
    gradeChange: 0
    friendshipChange: 0
    completesDate: 0
  - sceneId: 10
    lines:
    - speaker: "\uBBF8\uC694\uCF54"
      text: "\"\uC804\uCCA0 \uC5F0\uCC29?\" (\uD131\uC744 \uAD34\uACE0 \uC7A0\uC2DC
        \uB208\uC744 \uAC10\uB354\uB2C8 \uC911\uC5BC\uAC70\uB9B0\uB2E4.) \"9\uD638\uC120
        \uC804\uB3D9\uCC28\uC758 \uD45C\uC900\uC18D\uB3C4\uB294 35kn/h \uC5F0\uCC29
        \uD3C9\uADE0 \uAC70\uB9AC\uB294 1.2km, \uC624\uB298 \uC2E0\uD638\uC7A5\uC560
        \uAD6C\uAC04\uC758 \uAC10\uC18D\uC6B4\uD589\uB960\uC744 40%\uB85C \uC7A1\uACE0
        \uD478\uC559 \uCFE4\uC758 \uC5ED \uCD9C\uAD6C\uC5D0\uC11C \uC5EC\uAE30 \uBCA4\uCE58\uAE4C\uC9C0\uC758
        \uBCF4\uD589\uC18D\uB3C4\uB97C 4km/h\uB85C \uC0C1\uC815\uD558\uBA74\u2026\""
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uC5B4\uC774 \uC124\uB9C8 \uBA38\uB9BF\uC18D\uC73C\uB85C \uC9C0\uD558\uCCA0
        \uC9C0\uC5F0\uC2DC\uAC04\uC744 \uC2E4\uC2DC\uAC04\uC73C\uB85C \uC5ED\uC0B0\uD558\uACE0
        \uC788\uB294\uAC70\uC57C?!)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uBBF8\uC694\uCF54"
      text: "(\uB208\uC744 \uBC88\uCA4D \uB728\uBA70)\" \u2026\u2026\uC74C, \uACC4\uC0B0
        \uB05D\uB0AC\uC5B4. \uD655\uC2E4\uD788 \uB124\uAC00 \uC5ED\uC5D0\uC11C\uBD80\uD130
        \uAC00\uC18D\uB3C4\uB97C \uB192\uC5EC\uC11C \uC804\uB825 \uC9C8\uC8FC(v\u224818\_km/h)\uD588\uB2E4\uB294
        \uC870\uAC74 \uD558\uC5D0, 23.24\uCD08 \uC9C0\uAC01\uC740 \uBD88\uAC00\uD56D\uB825\uC801\uC778
        \uC218\uCE58\uC600\uB124.\" \"\uB370\uC774\uD130\uAC00 \uC99D\uBA85\uD558\uB2C8\uAE4C
        \uCC38\uC791\uD574 \uC904\uAC8C\""
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\uD734\uC6B0, \uACFC\uD559\uC801\uC774\uACE0 \uC218\uD559\uC801\uC778
        \uBCC0\uB860\uC774 \uD1B5\uD558\uB294 \uC6B0\uB4F1\uC0DD\uC774\uB77C \uB2E4\uD589\uC774\uB2E4\u2026\u2026!)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uBBF8\uC694\uCF54"
      text: "(\uC0B4\uC9DD \uBCFC\uC744 \uBD89\uD788\uBA70 \uC2A4\uB9C8\uD2B8\uC6CC\uCE58\uB97C
        \uB9CC\uC9C0\uC791\uAC70\uB9B0\uB2E4) \"\uD558\uC9C0\uB9CC\u2026\u2026 \uAC10\uC18D
        \uC6B4\uD589\uC774 \uC2DC\uC791\uB41C \uC2DC\uC810\uC5D0 \uC774\uBBF8 \uB098\uC5D0\uAC8C
        \uC9C0\uC5F0 \uB3C4\uB2EC \uC608\uC0C1 \uC2DC\uAC04\uC744 \uBA54\uC2E0\uC800\uB85C
        \uC1A1\uC2E0\uD588\uC5B4\uC57C \uACC4\uC0B0 \uC624\uCC28\uAC00 \uC548 \uC0DD\uAE30\uC796\uC544.
        \" \"\uAE30\uB2E4\uB9AC\uB294 \uB3D9\uC548\u2026\u2026 \uB0B4 \uC2EC\uBC15\uC218\uAC00
        \uD3C9\uC18C\uBCF4\uB2E4 15%\uB098 \uC0C1\uC2B9\uD588\uB2E4\uACE0. \uCC45\uC784\uC838\""
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    - speaker: "\uB098"
      text: "(\u2026\u2026\uD5C9, \uD654\uB09C \uAC8C \uC544\uB2C8\uB77C \uAE30\uB2E4\uB9AC\uB290\uB77C
        \uB450\uADFC\uAC70\uB838\uB2E4\uB294 \uB73B?! \uC774 \uAC2D \uBAA8\uC5D0,
        \uD30C\uAD34\uB825 \uC5C4\uCCAD\uB098\uC796\uC544!!)"
      backgroundId: 
      puangAppearanceId: 
      centerAppearanceId: 
      leftAppearanceId: 
      rightAppearanceId: 
    hasChoice: 0
    choiceTextA: 
    nextSceneA: -1
    affectionA: 0
