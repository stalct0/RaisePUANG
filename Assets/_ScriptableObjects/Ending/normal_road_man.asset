    \uD559\uAD50\uC5D0 \uC788\uB294 \uC2DC\uAC04\uBCF4\uB2E4 \uB3C4\uB85C \uC704\uB97C
    \uB2EC\uB9AC\uB294 \uC2DC\uAC04\uC774 \uB354 \uB9CE\uC558\uB2E4\uB294 \uC0AC\uC2E4\uC744\uC694.
    \uBE44\uB85D \uB300\uD559 \uACF5\uBD80\uB294 \uB2F9\uC2E0\uC758 \uD765\uBBF8\uB97C
    \uB04C\uC9C0 \uBABB\uD588\uC5B4\uB3C4, \uB2F9\uC2E0\uC740 \uB300\uD559 \uC2DC\uC808\uC758
    \uACBD\uD5D8\uC744 \uC0B4\uB824 \uC804\uC5C5 \uBC30\uB2EC\uAE30\uC0AC\uAC00 \uB418\uC5C8\uC2B5\uB2C8\uB2E4."
